FROM golang:1.22-alpine

RUN apk add --no-cache nodejs npm

WORKDIR /app

COPY go.mod ./
RUN go mod download

COPY package.json ./
RUN npm install

EXPOSE 3000

# In dev, the Makefile builds WASM + CSS locally and serves via python/file server.
# This image is primarily used for CI parity checks.
CMD ["sh", "-c", "echo 'Dev frontend: use `make dev-frontend` locally'"]
